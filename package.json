{
  "name": "work-summary",
  "version": "1.0.0",
  "private": true,
  "description": "智能工作总结生成器",
  "scripts": {
    "dev": "pnpm --filter @work-summary/shared build && concurrently \"pnpm --filter @work-summary/server dev\" \"pnpm --filter @work-summary/client dev\"",
    "dev:server": "pnpm --filter @work-summary/server dev",
    "dev:client": "pnpm --filter @work-summary/client dev",
    "build": "pnpm --filter @work-summary/shared build && pnpm --filter @work-summary/server build && pnpm --filter @work-summary/client build",
    "build:client": "pnpm --filter @work-summary/client build",
    "build:server": "pnpm --filter @work-summary/server build",
    "electron:build": "bash scripts/build-electron.sh",
    "electron:dev": "pnpm build && pnpm --filter @work-summary/electron build && electron packages/electron/dist/main.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
