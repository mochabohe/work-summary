{
  "name": "@work-summary/electron",
  "version": "1.0.1",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "pack": "electron-builder --win --x64",
    "pack:win": "electron-builder --win --x64",
    "pack:mac": "electron-builder --mac --universal",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.worksummary.app",
    "productName": "智能工作总结",
    "artifactName": "work-summary-setup-${version}.${ext}",
    "directories": {
      "output": "../../release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../server/server.cjs",
        "to": "server.cjs"
      },
      {
        "from": "../client/dist",
        "to": "client"
      },
      {
        "from": "../../.env",
        "to": ".env"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "artifactName": "work-summary-${version}-${arch}.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "智能工作总结"
    }
  }
}
