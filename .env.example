# ============================================
# 默认模型 Profile（启动时自动注册到"快速切换"列表）
# 两组 Profile 相互独立，可以只配一组，也可以都配。
# 任一组都 key+baseURL+model 三者齐备才会注册。
# ============================================

# —— 模型 1：GPT（第三方代理，OpenAI 兼容协议） ——
MODEL_GPT_PROVIDER=openai-compatible
MODEL_GPT_BASE_URL=https://your-gpt-proxy.example.com/v1
MODEL_GPT_API_KEY=sk-your-gpt-proxy-key
MODEL_GPT_NAME=gpt-5.5
# 可选：chat（默认）或 responses（gpt-5 / o1 / o3 等 reasoning 模型走 /v1/responses）
MODEL_GPT_API_TYPE=responses

# —— 模型 2：Claude Opus 4.7（第三方代理） ——
# provider 支持 anthropic（Anthropic 原生协议）或 openai-compatible（代理转成 OpenAI 格式）
MODEL_CLAUDE_PROVIDER=anthropic
MODEL_CLAUDE_BASE_URL=https://your-claude-proxy.example.com
MODEL_CLAUDE_API_KEY=sk-your-claude-proxy-key
MODEL_CLAUDE_NAME=claude-opus-4-7

# ============================================
# 兜底：DeepSeek（可选，UI 侧边栏依然可手动切换）
# 若上面两组都没填，才会退回这个作为默认 profile
# ============================================
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# 飞书开放平台配置 (从 https://open.feishu.cn/ 获取)
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 服务器端口
SERVER_PORT=3000

# Git 用户名 (用于过滤个人贡献)
GIT_AUTHOR=your_git_username

# 百度千帆 API Key (用于 AI PPT 导出, 从 https://console.bce.baidu.com/qianfan/ 获取)
BAIDU_API_KEY=your_baidu_api_key_here
